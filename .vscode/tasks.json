{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build SDL2 game",
            "type": "shell",
            "command": "g++",
            "args": [
                "src/*.cpp",
                "-Iinclude",
                "-IC:/SDL2/include",
                "-LC:/SDL2/lib",

                "-lmingw32",
                "-lSDL2main",
                "-lSDL2",

                "-o",
                "game.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}